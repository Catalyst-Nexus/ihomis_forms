VITE_LAB_UPLOAD_API_URL=https://your-hostname/api/laboratory-results/upload
# Fallback key used when VITE_LAB_UPLOAD_API_URL is not set
VITE_API_URL=
# Optional: endpoint used to preload request/patient context before upload
VITE_LAB_UPLOAD_CONTEXT_URL=
# Optional: comma-separated response paths used for exact context mapping
# Example: data.request.panel_name,request.panel_name
VITE_LAB_CONTEXT_PANEL_KEYS=
VITE_LAB_CONTEXT_REQUESTED_AT_KEYS=
VITE_LAB_CONTEXT_PATIENT_FIRST_KEYS=
VITE_LAB_CONTEXT_PATIENT_MIDDLE_KEYS=
VITE_LAB_CONTEXT_PATIENT_LAST_KEYS=
VITE_LAB_CONTEXT_PATIENT_FULLNAME_KEYS=
VITE_LAB_CONTEXT_ENCCODE_KEYS=
VITE_LAB_CONTEXT_FHUD_KEYS=
VITE_LAB_CONTEXT_DOCOINTKEY_KEYS=
# Optional: adds Authorization: Bearer <token> on upload requests
VITE_LAB_UPLOAD_API_TOKEN=
